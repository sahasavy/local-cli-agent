# =============================================================================
# Local CLI Agent - Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys.
#   cp .env.example .env
# =============================================================================

# --- LLM Provider (choose one: "openai" or "anthropic") ---
LLM_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Agent Settings ---
# Directory the agent can search/read files from
WORKSPACE_DIR=/Users/you/your-workspace

# Directory where notes are saved
NOTES_DIR=/Users/you/your-workspace/notes

# Maximum tool-call iterations per request (safety limit)
MAX_TOOL_ITERATIONS=10
