# =============================================================================
# Local CLI Agent - Configuration
# =============================================================================
# Copy this file to .env and fill in the API keys.
#   cp .env.example .env
# =============================================================================

# --- LLM Provider (pick one: "openai" or "anthropic") ---
LLM_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Agent Settings ---
# Root directory the agent operates on
WORKSPACE_DIR=/Users/sahasavy/Sourav/Projects

# Directory where notes get saved
NOTES_DIR=/Users/sahasavy/Sourav/Projects

# Safety limit - max tool-call iterations per request
MAX_TOOL_ITERATIONS=10

# --- Tool-Specific Settings ---

# Tavily API key for the web_search tool (https://tavily.com)
TAVILY_API_KEY=tvly-your-tavily-key-here

# Default SQLite database for the database_query tool (optional)
# DATABASE_PATH=/Users/dev/workspace/data.db
